<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.controllers.MainController"
            style="-fx-background-color: #eef0f4;">

    <!-- ══════════════════════ TOP ══════════════════════ -->
    <top>
        <VBox>

            <!-- App header -->
            <HBox style="-fx-background-color: #1a3a5c; -fx-padding: 14 20;"
                  alignment="CENTER_LEFT">
                <Label text="Player Performance Ranking System"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </HBox>

            <!-- Toolbar -->
            <HBox spacing="10"
                  style="-fx-padding: 10 16; -fx-background-color: #ffffff;
                         -fx-border-color: #d5dbe3; -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT">

                <Label text="Position:"
                       style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <ComboBox fx:id="positionFilter" promptText="All Positions" prefWidth="140"/>

                <Separator orientation="VERTICAL" prefHeight="24"/>

                <Label text="Top N:"
                       style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Spinner fx:id="topNSpinner" prefWidth="68" editable="false">
                    <valueFactory>
                        <SpinnerValueFactory.IntegerSpinnerValueFactory
                            min="1" max="100" initialValue="3"/>
                    </valueFactory>
                </Spinner>

                <Button text="Show Top N" onAction="#handleTopN"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 4;
                               -fx-cursor: hand; -fx-padding: 5 12;"/>
                <Button text="Show All" onAction="#handleShowAll"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 4;
                               -fx-cursor: hand; -fx-padding: 5 12;"/>

                <Separator orientation="VERTICAL" prefHeight="24"/>

                <Button text="Reset Stats" onAction="#handleResetStats"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 4;
                               -fx-cursor: hand; -fx-padding: 5 12;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════ CENTER ══════════════════════ -->
    <center>
        <SplitPane fx:id="splitPane" dividerPositions="0.52"
                   style="-fx-background-color: #eef0f4; -fx-padding: 12; -fx-box-border: transparent;">

            <!-- Left: player table -->
            <VBox style="-fx-background-color: #ffffff;
                         -fx-border-color: #d5dbe3; -fx-border-radius: 6;
                         -fx-background-radius: 6;">

                <HBox style="-fx-padding: 10 14; -fx-border-color: #d5dbe3;
                             -fx-border-width: 0 0 1 0; -fx-background-radius: 6 6 0 0;"
                      alignment="CENTER_LEFT">
                    <Label text="Players"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1a3a5c;"/>
                </HBox>

                <TableView fx:id="playerTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="nameColumn"     text="Name"     prefWidth="155"/>
                        <TableColumn fx:id="positionColumn" text="Position" prefWidth="105"/>
                        <TableColumn fx:id="teamColumn"     text="Team"     prefWidth="135"/>
                        <TableColumn fx:id="ageColumn"      text="Age"      prefWidth="55"/>
                        <TableColumn fx:id="scoreColumn"    text="Score"    prefWidth="90"/>
                    </columns>
                    <placeholder>
                        <Label text="No players to display."
                               style="-fx-text-fill: #aab2bd;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Right: detail panel -->
            <ScrollPane fx:id="detailScrollPane" fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-background: #eef0f4;">

                <VBox fx:id="detailPanel" spacing="0" visible="false">

                    <!-- Player identity card -->
                    <VBox style="-fx-background-color: #1a3a5c; -fx-padding: 16 18;
                                 -fx-background-radius: 6 6 0 0;">
                        <Label fx:id="playerNameLabel"
                               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <HBox spacing="18" style="-fx-padding: 5 0 0 0;">
                            <Label fx:id="positionLabel"
                                   style="-fx-text-fill: #a8c6e8; -fx-font-size: 12;"/>
                            <Label fx:id="teamLabel"
                                   style="-fx-text-fill: #a8c6e8; -fx-font-size: 12;"/>
                            <Label fx:id="ageLabel"
                                   style="-fx-text-fill: #a8c6e8; -fx-font-size: 12;"/>
                        </HBox>
                    </VBox>

                    <!-- Score banner -->
                    <HBox style="-fx-background-color: #27ae60; -fx-padding: 8 18;">
                        <Label fx:id="scoreLabel"
                               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    </HBox>

                    <!-- Body -->
                    <VBox spacing="14"
                          style="-fx-background-color: #ffffff; -fx-padding: 16;
                                 -fx-border-color: #d5dbe3; -fx-border-width: 0 1 1 1;
                                 -fx-background-radius: 0 0 6 6;">

                        <!-- Score breakdown -->
                        <VBox spacing="6">
                            <Label text="Score Breakdown"
                                   style="-fx-font-weight: bold; -fx-font-size: 12;
                                          -fx-text-fill: #555;"/>
                            <VBox fx:id="breakdownBox" spacing="2"
                                  style="-fx-background-color: #f4f6f8; -fx-padding: 10;
                                         -fx-background-radius: 4;"/>
                        </VBox>

                        <Separator/>

                        <!-- Performance record -->
                        <VBox spacing="6">
                            <Label text="Performance Record"
                                   style="-fx-font-weight: bold; -fx-font-size: 12;
                                          -fx-text-fill: #555;"/>
                            <VBox fx:id="statsBox" spacing="2"
                                  style="-fx-background-color: #f4f6f8; -fx-padding: 10;
                                         -fx-background-radius: 4;"/>
                        </VBox>

                        <Separator/>

                        <!-- Update form -->
                        <VBox spacing="8">
                            <Label text="Update Stats"
                                   style="-fx-font-weight: bold; -fx-font-size: 12;
                                          -fx-text-fill: #555;"/>
                            <Label text="Values are added on top of existing stats."
                                   style="-fx-font-style: italic; -fx-font-size: 11;
                                          -fx-text-fill: #888;"/>

                            <Label text="Primary Stats"
                                   style="-fx-font-weight: bold; -fx-font-size: 11;
                                          -fx-text-fill: #1a3a5c;"/>
                            <GridPane fx:id="primaryGrid" hgap="10" vgap="8"/>

                            <TitledPane fx:id="additionalPane"
                                        text="Additional Stats" expanded="false">
                                <GridPane fx:id="additionalGrid"
                                          hgap="10" vgap="8"
                                          style="-fx-padding: 10;"/>
                            </TitledPane>

                            <Label fx:id="errorLabel"
                                   style="-fx-text-fill: #c0392b;" wrapText="true"/>

                            <Button text="Submit Update"
                                    onAction="#handleSubmitUpdate"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-font-size: 13;
                                           -fx-background-radius: 4; -fx-padding: 8 0;
                                           -fx-cursor: hand;"/>
                        </VBox>

                    </VBox>
                </VBox>
            </ScrollPane>

        </SplitPane>
    </center>

    <!-- ══════════════════════ BOTTOM ══════════════════════ -->
    <bottom>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 6 16;">
            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #ecf0f1; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
